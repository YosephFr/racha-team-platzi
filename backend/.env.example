BACKEND_PORT=4036
FRONTEND_URL=http://localhost:4035

# Auth
JWT_SECRET=change-this-secret-in-production
BYPASS_OAUTH=true

# Database
DATABASE_PATH=./data/racha.db

# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_VISION_MODEL=gpt-4o
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=medium

# Streak rules (day of week: 0=Sunday, 1=Monday, ..., 6=Saturday)
STREAK_REQUIRED_DAYS=1,2,3,4,5
STREAK_OPTIONAL_DAYS=6,0
STREAK_EXCLUDED_DATES=

# WhatsApp
WA_NOTIFY_TARGETS=
WA_SESSION_PATH=./data/.wwebjs_auth
WA_CACHE_PATH=./data/.wwebjs_cache
