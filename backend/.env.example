BACKEND_PORT=4036
FRONTEND_URL=http://localhost:4035

# Auth
JWT_SECRET=
BYPASS_OAUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CORS
CORS_ORIGINS=

# Database
DATABASE_PATH=./data/racha.db

# AI providers (default: openai for both)
# Options for AI_CHAT_PROVIDER: openai | deepseek
# Options for AI_VISION_PROVIDER: openai | gemini
AI_CHAT_PROVIDER=openai
AI_VISION_PROVIDER=openai

# OpenAI (required if openai is selected for chat or vision)
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=medium

# DeepSeek — chat/text only, no vision. Required if AI_CHAT_PROVIDER=deepseek.
# Models: deepseek-v4-flash (default), deepseek-v4-pro (max quality)
# Legacy aliases deepseek-chat / deepseek-reasoner deprecate 2026-07-24
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=

# Gemini — vision only. Required if AI_VISION_PROVIDER=gemini.
# Models: gemini-2.5-flash (default), gemini-2.5-pro, gemini-2.5-flash-lite
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_VISION_MODEL=gemini-2.5-flash

# Streak rules (day of week: 0=Sunday, 1=Monday, ..., 6=Saturday)
STREAK_REQUIRED_DAYS=1,2,3,4,5
STREAK_OPTIONAL_DAYS=6,0
STREAK_EXCLUDED_DATES=

# WhatsApp
WA_NOTIFY_TARGETS=
WA_LOG_MESSAGES=false
WA_SESSION_PATH=./data/.wwebjs_auth
WA_CACHE_PATH=./data/.wwebjs_cache
