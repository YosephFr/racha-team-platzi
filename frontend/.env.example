# Backend URL the PWA will call. Use the public origin in production
# (the Nginx reverse proxy forwards /api/ to the backend).
NEXT_PUBLIC_API_URL=http://localhost:4036

# Comma-separated origins allowed by Next.js dev server (LAN/Tailscale, etc.).
# Only used when running `npm run dev`. Leave empty in production.
ALLOWED_DEV_ORIGINS=
