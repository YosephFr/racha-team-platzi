# === Server ===
BACKEND_PORT=4036
FRONTEND_URL=http://localhost:4035

# === Auth ===
JWT_SECRET=
BYPASS_OAUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === CORS ===
# Comma-separated list of allowed origins (defaults to FRONTEND_URL + http://localhost:4035)
CORS_ORIGINS=

# === Database ===
DATABASE_PATH=./data/racha.db

# === AI Providers ===
# Chat / agentic flow provider. Options: openai (default) | deepseek
AI_CHAT_PROVIDER=openai
# Vision / image analysis provider. Options: openai (default) | gemini
AI_VISION_PROVIDER=openai

# === OpenAI ===
# Required if AI_CHAT_PROVIDER=openai or AI_VISION_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=medium

# === DeepSeek (chat/text only — no vision) ===
# Required if AI_CHAT_PROVIDER=deepseek. Get key at https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Models: deepseek-v4-flash (default, fast/cheap), deepseek-v4-pro (1.6T params, max quality)
# Legacy aliases deepseek-chat / deepseek-reasoner still work, scheduled deprecation 2026-07-24
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
# Optional: cap output tokens
DEEPSEEK_MAX_TOKENS=

# === Gemini (vision only) ===
# Required if AI_VISION_PROVIDER=gemini. Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Models: gemini-2.5-flash (default), gemini-2.5-pro (max reasoning), gemini-2.5-flash-lite (cheapest)
GEMINI_VISION_MODEL=gemini-2.5-flash

# === ElevenLabs TTS ===
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_v3

# === Streak Rules ===
# Day of week: 0=Sunday, 1=Monday, ..., 6=Saturday
STREAK_REQUIRED_DAYS=1,2,3,4,5
STREAK_OPTIONAL_DAYS=6,0
# Dates excluded (holidays etc.) format: YYYY-MM-DD
STREAK_EXCLUDED_DATES=
# Hour at which streaks reset (in STREAK_TIMEZONE), default 4 (4 AM)
STREAK_RESET_HOUR=4
STREAK_TIMEZONE=America/Argentina/Buenos_Aires

# === WhatsApp ===
# Phone number for pairing code auth (no +, no spaces, e.g. 5491100000000)
WA_PRIMARY_PHONE=
# Comma-separated: group@g.us IDs for notifications
WA_NOTIFY_TARGETS=
# Log all incoming WhatsApp messages to console (default: false)
WA_LOG_MESSAGES=false
WA_SESSION_PATH=./data/.wwebjs_auth
WA_CACHE_PATH=./data/.wwebjs_cache

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:4036
